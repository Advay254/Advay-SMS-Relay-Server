# ─── SMS Relay Server — Environment Variables ────────────────────────────────
# Copy this file to .env and fill in values before running locally.
# On Render: set these in the Environment tab of your web service.

# PostgreSQL connection string from Supabase
# Found at: Supabase Dashboard → Project Settings → Database → Connection string (URI)
# Make sure to append ?sslmode=require if not already present
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Dashboard admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-please

# Shared API key used by MacroDroid and n8n to authenticate with this server
# Generate a strong random string: openssl rand -hex 32
API_KEY=replace-with-strong-random-key-32-chars-min

# Session encryption secret
# Generate: openssl rand -hex 32
SESSION_SECRET=replace-with-another-strong-random-key

# Port (Render sets this automatically; leave as 3000 for local dev)
PORT=3000

# Set to 'production' on Render (enables secure cookies)
NODE_ENV=production
